  "info": {
    "_postman_id": "a419718f-3533-4c42-aac1-dfdb78460d0b",
    "name": "Visa B2B Connect",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": {
      "content": "The Visa B2B Connect API provides direct settlement capabilities for large-value business-to-business cross-border transactions. Built on Visa's core payments infrastructure with distributed ledger technology, B2B Connect helps financial institutions and their clients overcome costly processes and geographic barriers for international B2B payments.\n\nContact Support:\n Name: Visa Developer Support",
      "type": "text/plain"
    }
  }
